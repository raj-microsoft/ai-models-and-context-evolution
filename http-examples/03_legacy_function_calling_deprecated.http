# 02 - Legacy Function Calling (DEPRECATED)
#
# ⚠️  This format is DEPRECATED as of November 2023
# 📚 Educational purpose: understand legacy code you might encounter
# 🔄 Key limitations: Only ONE function call per response, multiple API round-trips needed
#
# Legacy Format Uses:
# - "functions" parameter (instead of "tools")
# - "function_call" parameter (instead of "tool_choice") 
# - Response contains "function_call" (not "tool_calls")

POST {{AZURE_OPENAI_ENDPOINT}}openai/deployments/{{AZURE_OPENAI_GPT4O_DEPLOYMENT_NAME}}/chat/completions?api-version={{AZURE_OPENAI_GPT4O_API_VERSION}}
Content-Type: application/json
api-key: {{AZURE_OPENAI_API_KEY}}

{
  "messages": [
    {
      "role": "user",
      "content": "What's the weather like in Amsterdam?"
    }
  ],
  "functions": [
    {
      "name": "get_current_weather",
      "description": "Get the current weather in a given location",
      "parameters": {
        "type": "object",
        "properties": {
          "location": {
            "type": "string",
            "description": "The city and state/country, e.g. San Francisco, CA"
          },
          "unit": {
            "type": "string",
            "enum": ["celsius", "fahrenheit"],
            "description": "Temperature unit"
          }
        },
        "required": ["location"]
      }
    }
  ],
  "function_call": "auto",
  "max_tokens": 800,
  "temperature": 0.7
}
